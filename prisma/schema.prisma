// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  password      String
  role          String       @default("STUDENT") // ADMIN, HOD, TEACHER, STUDENT
  rollNumber    String?      @unique // University Register Number
  department    String?      // e.g., "Computer Science", "BCA", "BBA"
  semester      Int?         // 1-8 for students
  faceData      FaceData?
  enrollments   Enrollment[]
  teachings     Teaching[]
  attendances   Attendance[]
  sickLeaves    SickLeave[]  // For sick leave applications
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Subject {
  id            String       @id @default(cuid())
  code          String       @unique // e.g., "BCA301", "CS201"
  name          String
  credits       Int
  semester      Int
  department    String
  enrollments   Enrollment[]
  teachings     Teaching[]
  attendances   Attendance[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model FaceData {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  descriptor    String   // Store face descriptor as JSON string
  imageUrl      String?  // Optional: store reference image
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Enrollment {
  id            String   @id @default(cuid())
  studentId     String
  student       User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  academicYear  String   // e.g., "2025-2026"
  createdAt     DateTime @default(now())

  @@unique([studentId, subjectId, academicYear])
}

model Teaching {
  id            String   @id @default(cuid())
  teacherId     String
  teacher       User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  academicYear  String
  createdAt     DateTime @default(now())

  @@unique([teacherId, subjectId, academicYear])
}

model Attendance {
  id            String   @id @default(cuid())
  studentId     String
  student       User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  date          DateTime @default(now())
  period        Int      // 1st period, 2nd period, etc. (1-8)
  status        String   @default("PRESENT") // PRESENT, ABSENT, LATE, HOLIDAY
  markedBy      String   // Teacher ID who marked attendance
  confidence    Float?   // Face recognition confidence (0-1)
  createdAt     DateTime @default(now())
}

// Sick Leave Model - For students to apply for leave
model SickLeave {
  id          String   @id @default(cuid())
  studentId   String
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fromDate    DateTime // Start of leave
  toDate      DateTime // End of leave
  reason      String   // Reason for leave (no @db.Text for SQLite)
  documentUrl String?  // Path to uploaded file
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}